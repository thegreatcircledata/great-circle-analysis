{
  "description": "aDNA great circle connectivity analysis",
  "n_samples": 53,
  "n_pairs": 1378,
  "tests": {
    "raw_spearman": {
      "test": "GC_proximity vs genetic_distance (Spearman)",
      "rho": -0.0417,
      "p_value": 0.12162,
      "interpretation": "negative = closer to GC \u2192 more similar"
    },
    "isolation_by_distance": {
      "test": "geo_distance vs genetic_distance (Spearman)",
      "rho": 0.5613,
      "p_value": 3.2851e-115
    },
    "partial_correlation": {
      "test": "GC_proximity vs genetic_dist | geo_dist (partial Spearman)",
      "r_partial": 0.0592,
      "p_value": 0.028104,
      "monte_carlo_p": 0.2472,
      "n_permutations": 10000,
      "interpretation": "Tests GC effect AFTER removing geographic distance"
    },
    "binary_ancestry_test": {
      "both_near_gc_n": 210,
      "both_near_gc_same_rate": 0.0667,
      "both_far_gc_n": 496,
      "both_far_gc_same_rate": 0.1149,
      "mannwhitney_p": 0.97428
    }
  },
  "conclusion": "NOT SIGNIFICANT: GC proximity does not predict genetic similarity after controlling for distance (partial r=0.059, MC p=0.2472). No evidence of corridor-mediated connectivity."
}